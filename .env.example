# Paths
DATA_DIR=./data/clear_docs
LEXICAL_CACHE_PATH=./data/lexical_corpus.jsonl

# Milvus
MILVUS_URI=http://127.0.0.1:19530
COLLECTION=pcb_kb
MILVUS_EMBEDDING_FIELD=embedding

# Ollama
OLLAMA_BASE=http://127.0.0.1:11434
OLLAMA_LLM_MODEL=qwen3.5:35b-a3b-q4_K_M
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_NUM_CTX=8192
EMBED_NUM_CTX=2048
OLLAMA_TIMEOUT=300

# Document chunking
NODE_PARSER_MODE=parent_child
PARENT_MAX_SIZE=3000
PARENT_MIN_SIZE=200
CHILD_CHUNK_SIZE=512
CHILD_CHUNK_OVERLAP=128

# Retrieval
LEXICAL_ENABLED=1
RECALL_TOP_K=200
FUSION_MODE=RECIPROCAL_RANK
FUSION_WEIGHTS=0.45,0.55
FUSION_NUM_QUERIES=4
QUERY_EXPANSION_ENABLED=1
MULTI_EXPAND_ENABLED=1
HYDE_ENABLED=1
QUERY_ROUTING_ENABLED=1
CHUNK_EXPAND_ENABLED=1
CHUNK_EXPAND_NEIGHBORS=1
CHUNK_EXPAND_PARENT=1
CHUNK_GROUP_BY_DOC=1

# Rerank
RERANK_ENABLED=1
RERANK_BACKEND=qwen3reranker
RERANK_MODEL=Qwen/Qwen3-Reranker-4B
RERANK_TOP_N=200
HF_RERANK_MODEL=Qwen/Qwen3-Reranker-4B
HF_RERANK_MAX_LENGTH=1024
HF_RERANK_BATCH_SIZE=16
HF_RERANK_DEVICE=auto
HF_RERANK_DTYPE=auto
HF_ENDPOINT=https://hf-mirror.com

# Answer generation
CITATION_ENABLED=1
RAG_TOP_DOCS=5
RAG_DOC_MAX_CHARS=1000
SELF_RAG_ENABLED=0

# Dify API
DIFY_API_TOKEN=change-me
API_PORT=8000
SESSION_EXPIRE_MINUTES=60
SESSION_MAX_COUNT=1000
